# Degen — Environment Variables
# Copy to .env and fill in values.

# Solana wallet private key (base58 encoded, from Phantom export)
# NEVER commit this. Keep it only in .env
SOLANA_PRIVATE_KEY=

# Helius RPC URL (free tier: https://dev.helius.xyz)
# Required for fast Solana access. Public RPCs are too slow for trading.
HELIUS_RPC_URL=

# GMGN API key (if available — currently GMGN uses web interface)
# GMGN_API_KEY=

# Jito tip amount in SOL (default 0.001 = ~$0.14)
# Higher tips = faster block inclusion during high-demand periods
JITO_TIP_SOL=0.001

# Trading parameters
MAX_POSITION_SIZE_SOL=0.05
MAX_TRADES_PER_DAY=5
STOP_LOSS_PCT=15
TAKE_PROFIT_PCT=30
MAX_HOLD_MINUTES=10
